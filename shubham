Stored Procedures / Functions with Cursors
Create function to calculate total marks using cursor.

Code:
CREATE DATABASE College;
USE College;

-- TABLE CREATE
CREATE TABLE Student (
    Stud_ID INT PRIMARY KEY,
    Name VARCHAR(100),
    Marks INT
);

-- SAMPLE DATA
INSERT INTO Student
VALUES
(1, 'Rahul', 80),
(2, 'Amit', 70),
(3, 'Karan', 90),
(4, 'Sneha', 85);

-- FUNCTION WITH CURSOR (TOTAL MARKS)
DELIMITER //

CREATE FUNCTION TotalMarks()
RETURNS INT
DETERMINISTIC
BEGIN
    DECLARE done INT DEFAULT 0;
    DECLARE total INT DEFAULT 0;
    DECLARE m INT;

    DECLARE cur CURSOR FOR
        SELECT Marks FROM Student;

    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;

    OPEN cur;

    read_loop: LOOP
        FETCH cur INTO m;

        IF done = 1 THEN
            LEAVE read_loop;
        END IF;

        SET total = total + m;
    END LOOP;

    CLOSE cur;

    RETURN total;
END //

DELIMITER ;

-- CALL FUNCTION
SELECT TotalMarks();

