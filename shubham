Stored Procedures or Function with Cursors
Create procedure to display employee records using cursor.

Code:
CREATE DATABASE Company;
USE Company;

CREATE TABLE Employee (
    Emp_ID INT PRIMARY KEY,
    Name VARCHAR(100),
    Salary DECIMAL(10,2)
);

INSERT INTO Employee
VALUES
(1, 'Rahul', 25000),
(2, 'Amit', 30000),
(3, 'Karan', 40000);

DELIMITER //

CREATE PROCEDURE ShowEmployees()
BEGIN
    DECLARE done INT DEFAULT 0;
    DECLARE e_id INT;
    DECLARE e_name VARCHAR(100);
    DECLARE e_salary DECIMAL(10,2);

    DECLARE emp_cursor CURSOR FOR
        SELECT Emp_ID, Name, Salary FROM Employee;

    DECLARE CONTINUE HANDLER FOR NOT FOUND SET done = 1;

    OPEN emp_cursor;

    read_loop: LOOP
        FETCH emp_cursor INTO e_id, e_name, e_salary;

        IF done = 1 THEN
            LEAVE read_loop;
        END IF;

        SELECT e_id AS Emp_ID, e_name AS Name, e_salary AS Salary;
    END LOOP;

    CLOSE emp_cursor;
END //

DELIMITER ;

CALL ShowEmployees();



