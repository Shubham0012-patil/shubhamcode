Database Triggers
Create trigger to update stock automatically after product sale.
Code:
CREATE DATABASE Shop;
USE Shop;

-- Product table
CREATE TABLE Product (
    Product_ID INT PRIMARY KEY,
    Product_Name VARCHAR(100),
    Stock INT
);

-- Sales table
CREATE TABLE Sales (
    Sale_ID INT PRIMARY KEY,
    Product_ID INT,
    Quantity INT,
    FOREIGN KEY (Product_ID) REFERENCES Product(Product_ID)
);

-- Sample Data
INSERT INTO Product
VALUES
(1, 'Laptop', 50),
(2, 'Mouse', 100);

-- Trigger: Stock auto update after sale
DELIMITER //

CREATE TRIGGER Update_Stock_After_Sale
AFTER INSERT ON Sales
FOR EACH ROW
BEGIN
    UPDATE Product
    SET Stock = Stock - NEW.Quantity
    WHERE Product_ID = NEW.Product_ID;
END //

DELIMITER ;

-- Example sale (trigger will fire)
INSERT INTO Sales
VALUES (101, 1, 5);

-- Check updated stock
SELECT * FROM Product;

