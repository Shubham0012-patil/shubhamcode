CREATE DATABASE College;
USE College;

-- MAIN TABLE
CREATE TABLE Student (
    Stud_ID INT PRIMARY KEY,
    Name VARCHAR(100),
    Marks INT
);

-- BACKUP TABLE
CREATE TABLE Student_Backup (
    Stud_ID INT,
    Name VARCHAR(100),
    Marks INT,
    Deleted_At TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- SAMPLE DATA
INSERT INTO Student
VALUES
(1, 'Rahul', 80),
(2, 'Amit', 70),
(3, 'Karan', 90);

-- TRIGGER (store deleted record in backup table)
DELIMITER //

CREATE TRIGGER Backup_Deleted_Student
BEFORE DELETE ON Student
FOR EACH ROW
BEGIN
    INSERT INTO Student_Backup (Stud_ID, Name, Marks)
    VALUES (OLD.Stud_ID, OLD.Name, OLD.Marks);
END //

DELIMITER ;

